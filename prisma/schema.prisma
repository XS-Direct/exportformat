generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ExportModel {
  id             Int      @id @default(autoincrement())
  title          String
  type           String   @default("download") // download | export
  outputFormat   String   @default("custom")   // json | custom
  codeBefore     String
  repeatingCode  String
  codeAfter      String?
  mockFields     String? // JSON: array of mock field definitions
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("export_models")
}
